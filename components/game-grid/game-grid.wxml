<view
  class="rows-layer"
  style="transform: translateY({{boardOffsetPercent}}%); --grid-rows: {{gridRows}}; --grid-cols: {{gridCols}};"
>
  <view wx:for="{{renderRows}}" wx:key="id" class="board-row">
    <view wx:for="{{item.cells}}" wx:key="id" class="cell {{item.hasRoad ? 'road' : ''}} {{item.toneClass}} {{item.cellClass}}">
      <view wx:if="{{item.hasRoad}}" class="cell-pattern {{item.patternClass}}">
        <text class="animal-icon {{item.iconClass}}">{{item.patternIcon}}</text>
      </view>
    </view>
  </view>
</view>
