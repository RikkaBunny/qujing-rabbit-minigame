.penguin-sprite {
  position: absolute;
  left: 0;
  top: 0;
  transform: translate3d(-50%, -100%, 0) rotate(var(--tilt, 0deg)) scale(var(--stretch, 1));
  transform-origin: 50% 70%;
  width: 78rpx;
  height: 82rpx;
  z-index: 4;
  will-change: left, top;
  transition: left 70ms linear, top 70ms linear, transform 120ms cubic-bezier(0.22, 0.74, 0.24, 1);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.penguin {
  --face-scale: 1;
  width: 100%;
  height: 100%;
  position: relative;
  filter: drop-shadow(0 3rpx 7rpx rgba(52, 45, 58, 0.22));
  transform: scaleX(var(--face-scale));
}

.penguin-layer {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 90ms linear;
}

.penguin-front {
  opacity: 1;
}

.penguin.motion-forward .penguin-front,
.penguin.motion-left .penguin-front,
.penguin.motion-right .penguin-front {
  opacity: 0;
}

.penguin.motion-forward .penguin-back {
  opacity: 1;
}

.penguin.motion-left .penguin-side.side-left,
.penguin.motion-right .penguin-side.side-right {
  opacity: 1;
}

.penguin-body {
  position: absolute;
  left: 50%;
  top: 8rpx;
  width: 54rpx;
  height: 62rpx;
  transform: translateX(-50%);
  border-radius: 30rpx 30rpx 26rpx 26rpx;
  background: linear-gradient(180deg, #566477 0%, #4c586a 58%, #465263 100%);
  box-shadow: inset 0 4rpx 8rpx rgba(255, 255, 255, 0.16), inset 0 -3rpx 6rpx rgba(36, 44, 56, 0.2);
}

.penguin-belly {
  position: absolute;
  left: 50%;
  top: 17rpx;
  width: 34rpx;
  height: 32rpx;
  transform: translateX(-50%);
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fffaf5 0%, #f3e9e2 100%);
}

.penguin-eye {
  position: absolute;
  top: 17rpx;
  width: 6rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2a3442;
}

.penguin-eye::after {
  content: "";
  position: absolute;
  left: 1rpx;
  top: 1rpx;
  width: 2rpx;
  height: 2rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
}

.penguin-eye.eye-left {
  left: 16rpx;
}

.penguin-eye.eye-right {
  right: 16rpx;
}

.penguin-cheek {
  position: absolute;
  top: 26rpx;
  width: 7rpx;
  height: 5rpx;
  border-radius: 50%;
  background: rgba(248, 191, 201, 0.7);
}

.penguin-cheek.cheek-left {
  left: 12rpx;
}

.penguin-cheek.cheek-right {
  right: 12rpx;
}

.penguin-beak {
  position: absolute;
  left: 50%;
  top: 25rpx;
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-top: 8rpx solid #f5b37f;
  transform: translateX(-50%);
}

.penguin-shine {
  position: absolute;
  left: 9rpx;
  top: 8rpx;
  width: 11rpx;
  height: 9rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.penguin-back-body {
  background: linear-gradient(180deg, #515f74 0%, #465266 62%, #414d61 100%);
}

.penguin-back-mark {
  position: absolute;
  left: 50%;
  top: 15rpx;
  width: 22rpx;
  height: 28rpx;
  transform: translateX(-50%);
  border-radius: 14rpx;
  background: rgba(241, 247, 255, 0.16);
}

.penguin-shine.back-shine {
  left: auto;
  right: 10rpx;
  top: 10rpx;
  width: 9rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.12);
}

.penguin-wing {
  position: absolute;
  top: 30rpx;
  width: 16rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #5e6c7f 0%, #4f5c6d 100%);
}

.penguin-wing.wing-left {
  left: 6rpx;
  transform: rotate(16deg);
}

.penguin-wing.wing-right {
  right: 6rpx;
  transform: rotate(-16deg);
}

.penguin-wing.back-wing-left {
  left: 3rpx;
  background: linear-gradient(180deg, #4f5d71 0%, #435063 100%);
}

.penguin-wing.back-wing-right {
  right: 3rpx;
  background: linear-gradient(180deg, #4f5d71 0%, #435063 100%);
}

.penguin-foot {
  position: absolute;
  bottom: 2rpx;
  width: 16rpx;
  height: 9rpx;
  border-radius: 9rpx;
  background: #f3b782;
}

.penguin-foot.foot-left {
  left: 21rpx;
}

.penguin-foot.foot-right {
  right: 21rpx;
}

.penguin-side {
  transform-origin: 50% 66%;
}

.penguin-side.side-left {
  transform: scaleX(-1);
}

.penguin-side-body {
  position: absolute;
  left: 50%;
  top: 10rpx;
  width: 44rpx;
  height: 60rpx;
  transform: translateX(-50%);
  border-radius: 24rpx 24rpx 20rpx 20rpx;
  background: linear-gradient(180deg, #566477 0%, #495669 100%);
}

.penguin-side-belly {
  position: absolute;
  right: 5rpx;
  top: 17rpx;
  width: 20rpx;
  height: 30rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #fffaf5 0%, #f2e8df 100%);
}

.penguin-side-eye {
  position: absolute;
  right: 14rpx;
  top: 17rpx;
  width: 6rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #2a3442;
}

.penguin-side-eye::after {
  content: "";
  position: absolute;
  left: 1rpx;
  top: 1rpx;
  width: 2rpx;
  height: 2rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
}

.penguin-side-cheek {
  position: absolute;
  right: 10rpx;
  top: 27rpx;
  width: 6rpx;
  height: 4rpx;
  border-radius: 50%;
  background: rgba(248, 191, 201, 0.7);
}

.penguin-side-beak {
  position: absolute;
  right: 3rpx;
  top: 24rpx;
  width: 0;
  height: 0;
  border-top: 4rpx solid transparent;
  border-bottom: 4rpx solid transparent;
  border-left: 7rpx solid #f5b37f;
}

.penguin-side-wing {
  position: absolute;
  left: 14rpx;
  top: 32rpx;
  width: 13rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(180deg, #5a687d 0%, #4c586b 100%);
  transform: rotate(8deg);
}

.penguin-side-foot {
  position: absolute;
  bottom: 2rpx;
  width: 14rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #f3b782;
}

.penguin-side-foot.side-foot-front {
  right: 23rpx;
}

.penguin-side-foot.side-foot-back {
  right: 36rpx;
  opacity: 0.7;
}

.penguin.face-left {
  --face-scale: -1;
}

.penguin.face-right {
  --face-scale: 1;
}

.penguin.motion-forward,
.penguin.motion-left,
.penguin.motion-right {
  transform: scaleX(1);
}

.penguin.motion-idle {
  animation: penguin-idle 0.45s ease-in-out infinite alternate;
}

.penguin.motion-forward {
  animation: penguin-forward 0.36s ease-out;
}

.penguin.motion-left {
  animation: penguin-left 0.22s ease-out;
}

.penguin.motion-right {
  animation: penguin-right 0.22s ease-out;
}

.penguin.motion-blocked {
  animation: penguin-blocked 0.16s ease-out;
}

.penguin.motion-fall {
  animation: penguin-fall 0.45s ease-in forwards;
}

.penguin.motion-idle .penguin-wing.wing-left {
  animation: penguin-wing-flap-left 0.52s ease-in-out infinite alternate;
}

.penguin.motion-idle .penguin-wing.wing-right {
  animation: penguin-wing-flap-right 0.52s ease-in-out infinite alternate;
}

.penguin.motion-idle .penguin-side-wing,
.penguin.motion-left .penguin-side-wing,
.penguin.motion-right .penguin-side-wing {
  animation: penguin-side-wing-flap 0.42s ease-in-out infinite alternate;
}

@keyframes penguin-idle {
  from {
    transform: scaleX(var(--face-scale)) translateY(0);
  }
  to {
    transform: scaleX(var(--face-scale)) translateY(-3rpx);
  }
}

@keyframes penguin-forward {
  0% {
    transform: scaleX(1) translateY(0);
  }
  60% {
    transform: scaleX(1) translateY(-5rpx) scale(1.02);
  }
  100% {
    transform: scaleX(1) translateY(0);
  }
}

@keyframes penguin-left {
  0% {
    transform: scaleX(1) translateX(6rpx);
  }
  70% {
    transform: scaleX(1) translateX(-9rpx) rotate(-6deg);
  }
  100% {
    transform: scaleX(1) translateX(0);
  }
}

@keyframes penguin-right {
  0% {
    transform: scaleX(1) translateX(-6rpx);
  }
  70% {
    transform: scaleX(1) translateX(9rpx) rotate(6deg);
  }
  100% {
    transform: scaleX(1) translateX(0);
  }
}

@keyframes penguin-blocked {
  0% {
    transform: scaleX(var(--face-scale)) translateY(0) scale(1);
  }
  35% {
    transform: scaleX(var(--face-scale)) translateY(-6rpx) scale(1.02, 0.98);
  }
  100% {
    transform: scaleX(var(--face-scale)) translateY(0) scale(1);
  }
}

@keyframes penguin-fall {
  0% {
    transform: scaleX(var(--face-scale)) translateY(0);
    opacity: 1;
  }
  100% {
    transform: scaleX(var(--face-scale)) translateY(22rpx) rotate(18deg);
    opacity: 0.7;
  }
}

@keyframes penguin-wing-flap-left {
  from {
    transform: rotate(16deg);
  }
  to {
    transform: rotate(26deg);
  }
}

@keyframes penguin-wing-flap-right {
  from {
    transform: rotate(-16deg);
  }
  to {
    transform: rotate(-26deg);
  }
}

@keyframes penguin-side-wing-flap {
  from {
    transform: rotate(8deg);
  }
  to {
    transform: rotate(16deg);
  }
}
