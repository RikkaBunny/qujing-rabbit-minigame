}

.top-score.flame-tier-1,
.top-score.flame-tier-2,
.top-score.flame-tier-3,
.top-score.flame-tier-4,
.top-score.flame-tier-5 {
  animation: ui-panel-breath var(--breath-duration) ease-in-out infinite;
}

.ctrl-runner {
  position: relative;
  width: 88rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-mini-penguin {
  position: relative;
  z-index: 2;
  width: 36rpx;
  height: 38rpx;
  animation: ctrl-penguin-shuttle-right 1.08s ease-in-out infinite;
}

.ctrl-mini-body {
  position: absolute;
  left: 6rpx;
  top: 4rpx;
  width: 24rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #5d6a7d 0%, #4e5b6d 100%);
}

.ctrl-mini-belly {
  position: absolute;
  right: 8rpx;
  top: 11rpx;
  width: 10rpx;
  height: 13rpx;
  border-radius: 8rpx;
  background: #fff7f1;
}

.ctrl-mini-eye {
  position: absolute;
  right: 11rpx;
  top: 11rpx;
  width: 3rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #2b3543;
}

.ctrl-mini-beak {
  position: absolute;
  right: 4rpx;
  top: 14rpx;
  width: 0;
  height: 0;
  border-top: 2rpx solid transparent;
  border-bottom: 2rpx solid transparent;
  border-left: 5rpx solid #f5b37f;
}

.ctrl-mini-foot {
  position: absolute;
  right: 12rpx;
  bottom: 2rpx;
  width: 9rpx;
  height: 5rpx;
  border-radius: 8rpx;
  background: #f3b782;
}

.ctrl-runner-left .ctrl-mini-penguin {
  animation-name: ctrl-penguin-shuttle-left;
}

.ctrl-runner-right .ctrl-mini-penguin {
  animation-name: ctrl-penguin-shuttle-right;
}

.ctrl-runner-trails {
  position: absolute;
  top: 50%;
  width: 58rpx;
  height: 18rpx;
  transform: translateY(-50%);
}

.ctrl-runner-left .ctrl-runner-trails {
  right: -2rpx;
}

.ctrl-runner-right .ctrl-runner-trails {
  left: -2rpx;
}

.trail {
  position: absolute;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 251, 0.88);
  animation: ctrl-trail-fade 0.56s ease-in-out infinite;
}

.trail-1 {
  width: 26rpx;
  top: 2rpx;
}

.trail-2 {
  width: 18rpx;
  top: 11rpx;
  animation-delay: 0.14s;
}

.ctrl-runner-left .trail {
  right: 0;
}

.ctrl-runner-right .trail {
  left: 0;
}

.ctrl-btn[disabled] .ctrl-mini-penguin,
.ctrl-btn[disabled] .trail {
  opacity: 0.45;
  filter: none;
  animation-play-state: paused;
}

@keyframes ctrl-penguin-shuttle-right {
  0% {
    transform: translateX(-16rpx) translateY(0) scaleX(1) scale(1);
  }
  25% {
    transform: translateX(0) translateY(-2rpx) scaleX(1) scale(1.03);
  }
  50% {
    transform: translateX(16rpx) translateY(0) scaleX(1) scale(1);
  }
  75% {
    transform: translateX(0) translateY(-2rpx) scaleX(1) scale(1.03);
  }
  100% {
    transform: translateX(-16rpx) translateY(0) scaleX(1) scale(1);
  }
}

@keyframes ctrl-penguin-shuttle-left {
  0% {
    transform: translateX(16rpx) translateY(0) scaleX(-1) scale(1);
  }
  25% {
    transform: translateX(0) translateY(-2rpx) scaleX(-1) scale(1.03);
  }
  50% {
    transform: translateX(-16rpx) translateY(0) scaleX(-1) scale(1);
  }
  75% {
    transform: translateX(0) translateY(-2rpx) scaleX(-1) scale(1.03);
  }
  100% {
    transform: translateX(16rpx) translateY(0) scaleX(-1) scale(1);
  }
}

@keyframes ctrl-trail-fade {
  0% {
    opacity: 0.82;
    transform: scaleX(1);
  }
  50% {
    opacity: 0.42;
    transform: scaleX(0.72);
  }
  100% {
    opacity: 0.82;
    transform: scaleX(1);
  }
}

@keyframes ui-flame-flicker-a {
  0% {
    transform: translateX(0) translateY(0) scaleX(0.92);
  }
  50% {
    transform: translateX(calc(var(--flame-flicker-x) * -0.5)) translateY(calc(var(--flame-flicker-lift) * -1))
      scaleX(1.08);
  }
  100% {
    transform: translateX(0) translateY(0) scaleX(0.92);
  }
}

@keyframes ui-flame-flicker-b {
  0% {
    transform: translateX(0) translateY(0) scaleX(0.88);
  }
  50% {
    transform: translateX(calc(var(--flame-flicker-x) * 0.5)) translateY(calc(var(--flame-flicker-lift) * -1))
      scaleX(1.12);
  }
  100% {
    transform: translateX(0) translateY(0) scaleX(0.88);
  }
}

@keyframes ui-flame-rise {
  0% {
    transform: translateX(0) translateY(0) scaleY(0.86) rotate(-1deg);
  }
  50% {
    transform: translateX(calc(var(--flame-flicker-x) * 0.34)) translateY(calc(var(--flame-rise-lift) * -1)) scaleY(1.2)
      rotate(2.6deg);
  }
  100% {
    transform: translateX(0) translateY(0) scaleY(0.86) rotate(-1deg);
  }
}

@keyframes ui-flame-tongue {
  0% {
    border-radius: 70% 78% 64% 68% / 84% 88% 54% 58%;
  }
  50% {
    border-radius: 80% 66% 72% 58% / 88% 80% 60% 52%;
  }
  100% {
    border-radius: 70% 78% 64% 68% / 84% 88% 54% 58%;
  }
}

@keyframes ui-ghost-expand {
  0% {
    opacity: calc(var(--ghost-strength) * 0.84);
    transform: scale(0.94);
  }
  70% {
    opacity: calc(var(--ghost-strength) * 0.2);
    transform: scale(calc(var(--ghost-spread) * 1.1));
  }
  100% {
    opacity: 0;
    transform: scale(calc(var(--ghost-spread) * 1.22));
  }
}

@keyframes ui-ghost-expand-b {
  0% {
    opacity: 0;
    transform: scale(0.9);
  }
  45% {
    opacity: calc(var(--ghost-strength) * 0.62);
  }
  100% {
    opacity: 0;
    transform: scale(calc(var(--ghost-spread) * 1.3));
  }
}

@keyframes ui-panel-breath {
  0% {
    border-color: rgba(172, 228, 255, var(--breath-border-alpha));
    box-shadow:
      0 12rpx 24rpx rgba(172, 122, 150, 0.24),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
      0 0 0 rgba(94, 192, 255, 0),
      inset 0 0 0 rgba(146, 136, 255, 0);
  }
  50% {
    border-color: rgba(194, 153, 255, calc(var(--breath-border-alpha) + 0.08));
    box-shadow:
      0 12rpx 24rpx rgba(172, 122, 150, 0.24),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
      0 0 calc(26rpx * var(--breath-strength)) rgba(88, 197, 255, 0.58),
      inset 0 0 calc(18rpx * var(--breath-strength)) rgba(136, 128, 255, var(--breath-inner-alpha));
  }
  100% {
    border-color: rgba(172, 228, 255, var(--breath-border-alpha));
    box-shadow:
      0 12rpx 24rpx rgba(172, 122, 150, 0.24),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
      0 0 0 rgba(94, 192, 255, 0),
      inset 0 0 0 rgba(146, 136, 255, 0);
  }
}

.countdown-layer {
  position: absolute;
  inset: 0;
  z-index: 7;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.countdown-number {
  font-size: 168rpx;
  font-weight: 800;
  line-height: 1;
  color: rgba(255, 248, 252, 0.96);
  text-shadow: 0 6rpx 20rpx rgba(131, 96, 118, 0.34);
}

.countdown-a {
  animation: countdown-pop-a 0.82s ease-out;
}

.countdown-b {
  animation: countdown-pop-b 0.82s ease-out;
}

@keyframes menu-penguin-jump {
  0% {
    transform: translateX(-50%) translateY(0) scale(1);
  }
  40% {
    transform: translateX(-50%) translateY(-22rpx) scale(1.03);
  }
  100% {
    transform: translateX(-50%) translateY(0) scale(1);
  }
}

@keyframes menu-shadow-pulse {
  0% {
    transform: translateX(-50%) scaleX(1);
    opacity: 0.45;
  }
  40% {
    transform: translateX(-50%) scaleX(0.82);
    opacity: 0.25;
  }
  100% {
    transform: translateX(-50%) scaleX(1);
    opacity: 0.45;
  }
}

@keyframes countdown-pop-a {
  0% {
    opacity: 0;
    transform: scale(0.6);
  }
  26% {
    opacity: 1;
    transform: scale(1.08);
  }
  100% {
    opacity: 0;
    transform: scale(1.26);
  }
}

@keyframes countdown-pop-b {
  0% {
    opacity: 0;
    transform: scale(0.64);
  }
  24% {
    opacity: 1;
    transform: scale(1.04);
  }
  100% {
    opacity: 0;
    transform: scale(1.22);
  }
}

.overlay {
  position: absolute;
  inset: 0;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(205, 174, 190, 0.24);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.modal {
  width: 540rpx;
  border-radius: 28rpx;
  padding: 42rpx 38rpx;
  box-sizing: border-box;
  background: rgba(255, 251, 254, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(22rpx) saturate(132%);
  -webkit-backdrop-filter: blur(22rpx) saturate(132%);
  text-align: center;
  box-shadow: 0 18rpx 40rpx rgba(179, 129, 154, 0.24);
}

.start-modal {
  position: relative;
  padding-top: 54rpx;
}

.menu-modal {
  width: 560rpx;
  padding-top: 36rpx;
}

.menu-screen {
  position: absolute;
  inset: 0;
  z-index: 6;
  padding: calc(40rpx + env(safe-area-inset-top)) 34rpx calc(28rpx + env(safe-area-inset-bottom));
  padding: calc(40rpx + constant(safe-area-inset-top)) 34rpx calc(28rpx + constant(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(244, 219, 231, 0.2) 0%, rgba(234, 197, 216, 0.1) 100%);
}

.menu-content {
  width: 100%;
  height: 100%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.menu-mascot-wrap {
  position: relative;
  width: 180rpx;
  height: 150rpx;
  margin: 0 auto 10rpx;
}

.menu-mascot-shadow {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 108rpx;
  height: 24rpx;
  border-radius: 999rpx;
  transform: translateX(-50%);
  background: rgba(130, 96, 117, 0.24);
  filter: blur(2rpx);
  animation: menu-shadow-pulse 0.9s ease-in-out infinite;
}

.menu-mascot {
  position: absolute;
  left: 50%;
  bottom: 22rpx;
  transform: translateX(-50%);
  width: 106rpx;
  height: 112rpx;
  filter: drop-shadow(0 8rpx 14rpx rgba(100, 71, 88, 0.26));
  animation: menu-penguin-jump 0.9s ease-in-out infinite;
}

.menu-penguin-body {
  position: absolute;
  left: 50%;
  top: 8rpx;
  width: 76rpx;
  height: 84rpx;
  transform: translateX(-50%);
  border-radius: 42rpx 42rpx 34rpx 34rpx;
  background: linear-gradient(180deg, #5a677a 0%, #4f5c6e 58%, #485466 100%);
  box-shadow: inset 0 5rpx 10rpx rgba(255, 255, 255, 0.16), inset 0 -4rpx 8rpx rgba(36, 44, 56, 0.2);
}

.menu-penguin-belly {
  position: absolute;
  left: 50%;
  top: 32rpx;
  width: 46rpx;
  height: 42rpx;
  transform: translateX(-50%);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffaf5 0%, #f2e8df 100%);
}

.menu-penguin-eye {
  position: absolute;
  top: 34rpx;
  width: 8rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2a3442;
}

.menu-penguin-eye::after {
  content: "";
  position: absolute;
  left: 2rpx;
  top: 1rpx;
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
}

.menu-penguin-eye-left {
  left: 34rpx;
}

.menu-penguin-eye-right {
  right: 34rpx;
}

.menu-penguin-cheek {
  position: absolute;
  top: 47rpx;
  width: 10rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(248, 191, 201, 0.72);
}

.menu-penguin-cheek-left {
  left: 26rpx;
}

.menu-penguin-cheek-right {
  right: 26rpx;
}

.menu-penguin-beak {
  position: absolute;
  left: 50%;
  top: 45rpx;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-top: 10rpx solid #f5b37f;
  transform: translateX(-50%);
}

.menu-penguin-wing {
  position: absolute;
  top: 50rpx;
  width: 20rpx;
  height: 35rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #607084 0%, #536174 100%);
}

.menu-penguin-wing-left {
  left: 10rpx;
  transform: rotate(16deg);
}

.menu-penguin-wing-right {
  right: 10rpx;
  transform: rotate(-16deg);
}

.menu-penguin-foot {
  position: absolute;
  bottom: 7rpx;
  width: 20rpx;
  height: 10rpx;
  border-radius: 10rpx;
  background: #f3b782;
}

.menu-penguin-foot-left {
  left: 32rpx;
}

.menu-penguin-foot-right {
  right: 32rpx;
}

.menu-btn {
  margin-top: 14rpx;
  width: 82%;
}

.menu-exit-btn {
  background: linear-gradient(135deg, rgba(238, 205, 221, 0.72) 0%, rgba(232, 191, 212, 0.64) 100%);
}

.ranking-overlay {
  z-index: 8;
}

.ranking-modal {
  width: 520rpx;
  padding-top: 36rpx;
}

.ranking-title {
  margin-bottom: 12rpx;
}

.ranking-row {
  margin: 8rpx 0;
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.32);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ranking-rank {
  color: rgba(151, 109, 129, 0.9);
  font-size: 26rpx;
  font-weight: 700;
}

.ranking-score {
  color: rgba(140, 102, 121, 0.92);
  font-size: 28rpx;
}

.ranking-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.ranking-time {
  margin-top: 2rpx;
  color: rgba(146, 116, 131, 0.72);
  font-size: 19rpx;
}

.start-star {
  position: absolute;
  top: 20rpx;
  left: 34rpx;
  color: #dfb8a1;
  font-size: 32rpx;
}

.start-star.star-right {
  left: auto;
  right: 34rpx;
  font-size: 28rpx;
}

.title {
  font-size: 56rpx;
  color: #fffef8;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 3rpx 12rpx rgba(124, 136, 132, 0.24);
}

.subtitle {
  margin-top: 10rpx;
  font-size: 30rpx;
  color: rgba(148, 114, 130, 0.84);
}

.desc,
.best,
.score-line {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: rgba(139, 108, 123, 0.82);
  line-height: 1.45;
}

.main-btn,
.share-btn {
  margin-top: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  font-size: 32rpx;
  color: #fffef7;
  background: linear-gradient(135deg, rgba(244, 199, 221, 0.78) 0%, rgba(237, 187, 212, 0.7) 100%);
  backdrop-filter: blur(14rpx) saturate(132%);
  -webkit-backdrop-filter: blur(14rpx) saturate(132%);
  box-shadow: 0 10rpx 22rpx rgba(172, 122, 150, 0.26);
}

.main-btn::after,
.share-btn::after {
  border: none;
}

.share-btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, rgba(246, 208, 226, 0.74) 0%, rgba(238, 193, 216, 0.66) 100%);
}
