  --flame-glow-opacity: 0.18;
  --flame-core-opacity: 0.12;
  --flame-glow-height: 18rpx;
  --flame-core-height: 26rpx;
  --flame-flicker-lift: 1.2rpx;
  --flame-rise-lift: 1.8rpx;
  --flame-flicker-x: 1.2rpx;
  --flame-flicker-duration: 1.14s;
  --flame-rise-duration: 1.32s;
  --ghost-strength: 0.22;
  --ghost-spread: 1;
  --ghost-duration: 1.62s;
  --breath-strength: 0.28;
  --breath-duration: 1.62s;
  --breath-border-alpha: 0.42;
  --breath-inner-alpha: 0.2;
