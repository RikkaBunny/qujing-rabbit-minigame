page {
  height: 100%;
}

.page {
  position: relative;
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.bg-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, #b8c5d6 0%, #9db4c0 38%, #89a4b7 100%);
}

.bg-glow {
  position: absolute;
  left: 50%;
  top: -12%;
  width: 130%;
  height: 58%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse at center, rgba(254, 239, 219, 0.58) 0%, rgba(254, 239, 219, 0) 72%);
}

.bg-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(245, 241, 234, 0.5);
  filter: blur(2rpx);
}

.cloud-a {
  top: 160rpx;
  left: -36rpx;
  width: 220rpx;
  height: 72rpx;
}

.cloud-b {
  top: 240rpx;
  right: -28rpx;
  width: 186rpx;
  height: 62rpx;
}

.snow-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.snowflake {
  position: absolute;
  top: -40rpx;
  border-radius: 50%;
  background: rgba(248, 246, 240, 0.88);
  animation-name: snow-fall;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
}

@keyframes snow-fall {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(130vh);
  }
}

.hud {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  color: #fffdf9;
  font-size: 26rpx;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.25);
}

.hud-item {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(109, 133, 148, 0.42);
  backdrop-filter: blur(6rpx);
}

.music-btn {
  position: absolute;
  right: 28rpx;
  top: 84rpx;
  z-index: 4;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #fcf9f2;
  background: rgba(109, 133, 148, 0.55);
  box-shadow: 0 6rpx 14rpx rgba(55, 70, 82, 0.2);
}

.board-wrap {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx 8rpx;
  box-sizing: border-box;
}

.board {
  position: relative;
  width: 100%;
  max-width: 680rpx;
  aspect-ratio: 9 / 14;
  border-radius: 36rpx;
  overflow: hidden;
  background: rgba(230, 235, 236, 0.24);
  box-shadow: inset 0 0 30rpx rgba(247, 245, 239, 0.25), 0 16rpx 44rpx rgba(64, 82, 98, 0.24);
}


.score-float {
  position: absolute;
  left: 50%;
  top: 22%;
  transform: translateX(-50%);
  color: #f8dc9a;
  font-size: 40rpx;
  font-weight: 700;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.2);
  animation: score-rise 0.7s ease-out;
}

@keyframes score-rise {
  0% {
    opacity: 0;
    transform: translate(-50%, 16rpx) scale(0.85);
  }
  40% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -24rpx) scale(1.05);
  }
}

.controls {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  padding: 12rpx 56rpx 44rpx;
}

.ctrl-btn {
  width: 160rpx;
  height: 96rpx;
  border-radius: 999rpx;
  border: none;
  color: #fcf9f2;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 96rpx;
  background: linear-gradient(180deg, rgba(131, 155, 168, 0.86) 0%, rgba(108, 131, 144, 0.9) 100%);
  box-shadow: 0 10rpx 22rpx rgba(61, 78, 92, 0.28);
}

.ctrl-btn[disabled] {
  color: rgba(252, 249, 242, 0.62);
  background: rgba(126, 146, 157, 0.36);
  box-shadow: none;
}

.overlay {
  position: absolute;
  inset: 0;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(44, 59, 74, 0.42);
}

.modal {
  width: 540rpx;
  border-radius: 36rpx;
  padding: 42rpx 38rpx;
  box-sizing: border-box;
  background: rgba(246, 243, 236, 0.96);
  text-align: center;
  box-shadow: 0 16rpx 44rpx rgba(63, 81, 97, 0.24);
}

.start-modal {
  position: relative;
  padding-top: 54rpx;
}

.start-star {
  position: absolute;
  top: 20rpx;
  left: 34rpx;
  color: #d7be8f;
  font-size: 32rpx;
}

.start-star.star-right {
  left: auto;
  right: 34rpx;
  font-size: 28rpx;
}

.title {
  font-size: 56rpx;
  color: #4f6678;
  font-weight: 700;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 30rpx;
  color: #6f8797;
}

.desc,
.best,
.score-line {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #698092;
  line-height: 1.45;
}

.main-btn,
.share-btn {
  margin-top: 26rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 32rpx;
  color: #fcf9f2;
  background: linear-gradient(180deg, #8fa8b0 0%, #79939f 100%);
  box-shadow: 0 10rpx 20rpx rgba(83, 103, 115, 0.25);
}

.share-btn {
  margin-top: 16rpx;
  background: linear-gradient(180deg, #9eb2b9 0%, #8ca2ad 100%);
}
