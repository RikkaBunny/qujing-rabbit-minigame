.top-score.flame-tier-4,
.top-score.flame-tier-5 {
  --flame-core-inset: 18%;
  --flame-core-bottom: -28rpx;
}

.ctrl-btn.flame-tier-4,
.ctrl-btn.flame-tier-5 {
