page {
  height: 100%;
  background: #f3ebef;
}

.page {
  position: relative;
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.bg-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, #f8eff3 0%, #f3e9ee 42%, #f7f1f4 100%);
}

.bg-glow {
  position: absolute;
  right: -10%;
  top: -14%;
  width: 72%;
  height: 48%;
  border-radius: 50%;
  background: radial-gradient(circle at center, rgba(255, 232, 240, 0.78) 0%, rgba(255, 232, 240, 0) 74%);
}

.bg-stripes {
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(18deg, rgba(255, 255, 255, 0.11) 0rpx, rgba(255, 255, 255, 0.11) 8rpx, transparent 8rpx, transparent 30rpx);
  opacity: 0.12;
}

.bg-diag {
  position: absolute;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
}

.bg-diag.diag-a {
  top: 20%;
  left: -8%;
  width: 32%;
  transform: rotate(-8deg);
}

.bg-diag.diag-b {
  top: 74%;
  right: -6%;
  width: 30%;
  transform: rotate(-9deg);
  background: rgba(236, 206, 219, 0.34);
}

.bg-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 245, 248, 0.42);
  filter: blur(2rpx);
}

.cloud-a {
  top: 168rpx;
  left: -18rpx;
  width: 220rpx;
  height: 62rpx;
}

.cloud-b {
  top: 292rpx;
  right: -20rpx;
  width: 196rpx;
  height: 54rpx;
}

.snow-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.snowflake {
  position: absolute;
  top: -40rpx;
  border-radius: 50%;
  background: rgba(252, 248, 241, 0.88);
  animation-name: snow-fall;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
}

@keyframes snow-fall {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(130vh);
  }
}

.top-bar {
  position: absolute;
  top: calc(22rpx + env(safe-area-inset-top));
  top: calc(22rpx + constant(safe-area-inset-top));
  left: 18rpx;
  right: 18rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.top-icon-btn,
.top-score {
  height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(244, 199, 221, 0.66) 0%, rgba(236, 189, 211, 0.58) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(18rpx) saturate(132%);
  -webkit-backdrop-filter: blur(18rpx) saturate(132%);
  box-shadow: 0 12rpx 24rpx rgba(172, 122, 150, 0.24), inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
}

.top-icon-btn {
  width: 64rpx;
  min-width: 64rpx;
  padding: 0;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff7fb;
  font-size: 30rpx;
}

.top-icon-btn::after {
  border: none;
}

.top-icon {
  line-height: 1;
  color: #fff7fb;
  text-shadow: 0 2rpx 6rpx rgba(146, 103, 121, 0.3);
}

.top-music-icon-wrap {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-icon-music {
  font-size: 30rpx;
}

.top-icon-slash {
  position: absolute;
  right: -2rpx;
  top: -4rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff7fb;
  text-shadow: 0 2rpx 6rpx rgba(146, 103, 121, 0.3);
}

.top-pause-icon-wrap {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.top-pause-bar {
  width: 8rpx;
  height: 26rpx;
  border-radius: 99rpx;
  background: #fff7fb;
  box-shadow: 0 2rpx 6rpx rgba(146, 103, 121, 0.3);
}

.top-play-icon {
  width: 0;
  height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 20rpx solid #fff7fb;
  filter: drop-shadow(0 2rpx 6rpx rgba(146, 103, 121, 0.3));
}

.top-score {
  min-width: 260rpx;
  padding: 12rpx 26rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: visible;
  transition: border-color 180ms ease, box-shadow 180ms ease;
}

.top-score-label,
.top-score-value {
  display: block;
}

.top-score-label {
  color: rgba(255, 248, 253, 0.98);
  font-size: 20rpx;
  letter-spacing: 2.5rpx;
  text-shadow: 0 2rpx 8rpx rgba(153, 102, 129, 0.35);
}

.top-score-value {
  margin-top: 3rpx;
  color: #fffef8;
  font-size: 42rpx;
  font-weight: 700;
  text-shadow: 0 3rpx 10rpx rgba(153, 102, 129, 0.4);
}

.top-score-label,
.top-score-value {
  position: relative;
  z-index: 2;
}

.top-score,
.ctrl-btn {
  --flame-glow-opacity: 0;
  --flame-core-opacity: 0;
  --flame-halo-opacity: 0;
  --flame-glow-inset: 10%;
  --flame-glow-bottom: -12rpx;
  --flame-glow-height: 24rpx;
  --flame-glow-blur: 2rpx;
  --flame-core-inset: 22%;
  --flame-core-bottom: -22rpx;
  --flame-core-height: 42rpx;
  --flame-core-blur: 1rpx;
  --flame-flicker-lift: 2rpx;
  --flame-flicker-x: 2rpx;
  --flame-rise-lift: 3rpx;
  --flame-flicker-duration: 0.9s;
  --flame-rise-duration: 1.15s;
  --ghost-strength: 0;
  --ghost-spread: 1;
  --ghost-duration: 1.45s;
  --breath-strength: 0;
  --breath-duration: 1.45s;
  --breath-border-alpha: 0;
  --breath-inner-alpha: 0;
}

.ui-ghost-aura {
  position: absolute;
  inset: -10rpx;
  border-radius: inherit;
  pointer-events: none;
  z-index: 0;
}

.ui-ghost-aura::before,
.ui-ghost-aura::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0;
  background: linear-gradient(
    90deg,
    rgba(92, 210, 255, 0.74) 0%,
    rgba(122, 189, 255, 0.5) 45%,
    rgba(148, 144, 255, 0.48) 58%,
    rgba(184, 114, 255, 0.74) 100%
  );
  box-shadow: 0 0 18rpx rgba(96, 178, 255, 0.26), 0 0 22rpx rgba(164, 124, 255, 0.26);
  filter: blur(3rpx);
  transform: scale(0.96);
}

.ui-ghost-aura::before {
  animation: ui-ghost-expand var(--ghost-duration) ease-out infinite;
}

.ui-ghost-aura::after {
  animation: ui-ghost-expand-b calc(var(--ghost-duration) * 1.06) ease-out infinite;
}

.top-score::before,
.top-score::after,
.ctrl-btn::before {
  content: "";
  position: absolute;
  pointer-events: none;
  opacity: 0;
}

.top-score::before {
  left: -10rpx;
  right: -10rpx;
  top: -10rpx;
  bottom: -10rpx;
  height: auto;
  border-radius: 999rpx;
  background:
    radial-gradient(60% 50% at 50% 6%, rgba(195, 246, 255, 0.9) 0%, rgba(116, 212, 255, 0.64) 46%, rgba(74, 132, 250, 0) 100%),
    radial-gradient(90% 68% at 50% 112%, rgba(80, 138, 255, 0.42) 0%, rgba(73, 122, 246, 0.18) 52%, rgba(73, 122, 246, 0) 100%),
    radial-gradient(100% 90% at 50% 50%, rgba(80, 142, 255, 0.22) 0%, rgba(80, 142, 255, 0) 74%);
  filter: blur(var(--flame-glow-blur));
  opacity: var(--flame-halo-opacity);
  animation: ui-flame-flicker-a var(--flame-flicker-duration) ease-in-out infinite;
}

.top-score::after {
  left: var(--flame-core-inset);
  right: var(--flame-core-inset);
  top: calc(var(--flame-core-bottom) * -1 - 6rpx);
  height: var(--flame-core-height);
  border-radius: 72% 78% 64% 68% / 82% 86% 54% 58%;
  background:
    radial-gradient(44% 54% at 52% 16%, rgba(233, 252, 255, 0.98) 0%, rgba(205, 236, 255, 0.94) 52%, rgba(205, 236, 255, 0) 100%),
    radial-gradient(30% 48% at 36% 48%, rgba(166, 222, 255, 0.86) 0%, rgba(132, 179, 255, 0.5) 66%, rgba(132, 179, 255, 0) 100%),
    radial-gradient(30% 48% at 70% 48%, rgba(166, 215, 255, 0.8) 0%, rgba(126, 157, 255, 0.46) 64%, rgba(126, 157, 255, 0) 100%),
    linear-gradient(180deg, rgba(191, 231, 255, 0.96) 0%, rgba(134, 172, 255, 0.82) 54%, rgba(88, 106, 236, 0) 100%);
  filter: blur(var(--flame-core-blur));
  opacity: var(--flame-core-opacity);
  transform-origin: 50% 18%;
  animation:
    ui-flame-rise var(--flame-rise-duration) ease-in-out infinite,
    ui-flame-tongue calc(var(--flame-rise-duration) * 0.86) ease-in-out infinite;
  box-shadow: 0 0 22rpx rgba(116, 186, 255, 0.36);
}

.encourage-tip {
  position: absolute;
  left: 18rpx;
  top: 110rpx;
  z-index: 5;
  width: 320rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: linear-gradient(135deg, rgba(246, 207, 227, 0.76) 0%, rgba(239, 195, 218, 0.66) 100%);
  backdrop-filter: blur(18rpx) saturate(132%);
  -webkit-backdrop-filter: blur(18rpx) saturate(132%);
  box-shadow: 0 14rpx 26rpx rgba(170, 114, 145, 0.24), inset 0 1rpx 0 rgba(255, 255, 255, 0.46);
  pointer-events: none;
  animation: encourage-tip-enter 0.32s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.encourage-tip-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.35);
  color: rgba(161, 92, 125, 0.92);
  font-size: 20rpx;
  font-weight: 700;
}

.encourage-tip-text {
  margin-top: 8rpx;
  color: rgba(255, 248, 252, 0.98);
  font-size: 25rpx;
  line-height: 1.45;
  text-shadow: 0 2rpx 8rpx rgba(149, 96, 127, 0.34);
}

.encourage-tip-milestone {
  margin-top: 7rpx;
  color: rgba(161, 92, 125, 0.86);
  font-size: 20rpx;
}

@keyframes encourage-tip-enter {
  0% {
    opacity: 0;
    transform: translateX(-26rpx) scale(0.96);
  }
  100% {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

.board-wrap {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.board {
  position: relative;
  width: 100vw;
  height: 100vh;
  border-radius: 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  box-shadow: inset 0 0 22rpx rgba(255, 255, 255, 0.3), 0 16rpx 38rpx rgba(170, 132, 149, 0.18);
}

.score-float {
  position: absolute;
  left: 50%;
  top: 22%;
  transform: translateX(-50%);
  color: #f5ccb2;
  font-size: 40rpx;
  font-weight: 700;
  text-shadow: 0 4rpx 14rpx rgba(198, 174, 140, 0.36);
  animation: score-rise 0.7s ease-out;
}

.bonus-float {
  position: absolute;
  left: 50%;
  top: 30%;
  transform: translateX(-50%);
  color: #fff7cf;
  font-size: 46rpx;
  font-weight: 800;
  text-shadow: 0 4rpx 14rpx rgba(219, 172, 92, 0.45), 0 0 10rpx rgba(255, 247, 212, 0.6);
  animation: score-rise 0.76s ease-out;
}

@keyframes score-rise {
  0% {
    opacity: 0;
    transform: translate(-50%, 16rpx) scale(0.85);
  }
  40% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -24rpx) scale(1.05);
  }
}

.controls {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(26rpx + env(safe-area-inset-bottom));
  bottom: calc(26rpx + constant(safe-area-inset-bottom));
  z-index: 5;
  display: flex;
  justify-content: space-between;
  padding: 10rpx 34rpx 0;
}

.touch-zones {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 34%;
  z-index: 4;
  display: flex;
}

.touch-zone {
  flex: 1;
  height: 100%;
}

.ctrl-btn {
  width: 210rpx;
  height: 96rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.64);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(244, 199, 221, 0.66) 0%, rgba(236, 189, 211, 0.58) 100%);
  backdrop-filter: blur(18rpx) saturate(132%);
  -webkit-backdrop-filter: blur(18rpx) saturate(132%);
  box-shadow: 0 12rpx 24rpx rgba(172, 122, 150, 0.24), inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
  position: relative;
  overflow: visible;
  --flame-glow-inset: 8%;
  --flame-glow-bottom: -14rpx;
  --flame-glow-height: 28rpx;
  transition: border-color 180ms ease, box-shadow 180ms ease;
}

.ctrl-btn::after {
  border: none;
}

.ctrl-btn::before {
  display: none;
}

.ctrl-btn[disabled] {
  background: rgba(238, 220, 228, 0.34);
  box-shadow: none;
  animation: none !important;
}

.ctrl-runner {
  overflow: visible;
}

.ctrl-runner::before {
  display: none;
}

.ctrl-btn[disabled]::before,
.ctrl-btn[disabled] .ctrl-runner::before,
.top-score.flame-tier-0::before,
.top-score.flame-tier-0::after,
.ctrl-btn.flame-tier-0::before {
  opacity: 0;
}

.ctrl-btn.flame-tier-0 .ctrl-runner::before {
  opacity: 0;
}

.flame-tier-0 .ui-ghost-aura::before,
.flame-tier-0 .ui-ghost-aura::after,
.ctrl-btn[disabled] .ui-ghost-aura::before,
.ctrl-btn[disabled] .ui-ghost-aura::after {
  opacity: 0 !important;
  animation: none;
}

